{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "resourcePrefix": {
      "value": "hr-policy-kb"
    },
    "openAIDeploymentName": {
      "value": "gpt-5-mini"
    },
    "gpt5DeploymentName": {
      "value": "gpt-5"
    },
    "embeddingDeploymentName": {
      "value": "text-embedding-3-small"
    },
    "searchSku": {
      "value": "basic"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "backendAuthClientId": {
      "value": "${AZURE_BACKEND_AUTH_CLIENT_ID=}"
    },
    "searchLocation": {
      "value": "${AZURE_SEARCH_LOCATION=}"
    },
    "backendImage": {
      "value": "${AZURE_BACKEND_IMAGE=}"
    }
  }
}
