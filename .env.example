# =============================================================================
# HR Policy Knowledge Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Microsoft Foundry / Project
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/yourProject
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/yourProject
AZURE_AI_PROJECT_RESOURCE_ID=/subscriptions/<your-subscription-id>/resourceGroups/<your-resource-group>/providers/Microsoft.CognitiveServices/accounts/<your-cognitive-service>/projects/<your-project>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_api_key
# Chat / answer-synthesis model deployment (GPT-4o retired for generative
# orchestration Oct 2025; this repo's infra deploys gpt-5-mini). See
# src/config/model_policy.py.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini
# Optional: FOUNDRY_MODEL takes precedence over AZURE_OPENAI_DEPLOYMENT_NAME
# (e.g. gpt-5, gpt-4.1, claude-sonnet-4-6).
# FOUNDRY_MODEL=gpt-5
# Optional: embedding model deployment for index/query vectorization
# (defaults to text-embedding-3-small; embedding config also lives in
# src/config/search_config.json -> "embedding").
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/


# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your_search_admin_key
AZURE_SEARCH_INDEX_NAME=hr-policy-index

# Azure AI Search Connection (for Foundry Agent)
AI_SEARCH_PROJECT_CONNECTION_ID=your_connection_id

# Authentication
# true = Use Managed Identity / AzureCliCredential (recommended)
# false = Use API key authentication
USE_MANAGED_IDENTITY=true

# Agent Service Selection (only matters when running Pattern B or the Hosted Agent runtime)
# agent-framework = Microsoft Agent Framework SDK / Hosted Agent runtime (default)
# foundry         = Microsoft Foundry Agent Service prompt agent + MCPTool (Pattern B)
AGENT_SERVICE=agent-framework

# Retrieval Mode for the Agent Framework / Hosted Agent path (RAG strategy)
# tool             = custom @tool classic search (default)
# context-semantic = out-of-the-box context provider, classic (index) search
# context-agentic  = out-of-the-box context provider, agentic retrieval over the
#                    Foundry IQ knowledge base (hr-knowledge-base)
RETRIEVAL_MODE=tool

# Retrieval Pattern (documentation-only switch — see docs/RetrievalPatterns.md)
# A = Direct Knowledge Base — Copilot Studio queries Azure AI Search KB directly (default; start here)
# B = Foundry Agent Service prompt agent with MCP tool
# C = Dual-Tool Routing (POST /api/lookup + askHRPolicy or KB)
ORCHESTRATOR_PATTERN=A

# Search Mode
# integrated_vectorization = Use indexer + skillset pipeline with server-side chunking/embedding (default)
# legacy = Use client-side chunking and embedding via HRPolicySearchService
SEARCH_MODE=integrated_vectorization

# Copilot Studio (optional)
COPILOT_STUDIO_ENVIRONMENT_ID=your_environment_id
COPILOT_STUDIO_BOT_ID=your_bot_id
COPILOT_STUDIO_AGENT_SCHEMA=your_agent_schema
COPILOT_STUDIO_REGION=your_region
# Override with the full token endpoint URL if the constructed URL doesn't work:
# COPILOT_STUDIO_TOKEN_ENDPOINT=https://your-region.api.powerplatform.com/powervirtualagents/botsbyschema/your-schema/directline/token

# Knowledge Base Path
KNOWLEDGE_BASE_PATH=./data/knowledge_base/ASK HR Knowledge

# Logging and Monitoring
LOG_LEVEL=INFO
# GenAI tracing (AIProjectInstrumentor). true = emit agent/model/tool spans
# (default); false = disable. See src/observability/tracing.py.
ENABLE_TRACING=true
# Application Insights connection string for Azure Monitor / Foundry
# Observability export. Use this EXACT name (Azure Monitor standard). When unset,
# spans export to the console.
APPLICATIONINSIGHTS_CONNECTION_STRING=your_app_insights_connection_string

# ============================================
# EXTRACTION BACKEND CONFIGURATION
# ============================================
# Options: document_intelligence (default), content_understanding
EXTRACTION_BACKEND=document_intelligence

# ============================================
# BLOB STORAGE CONFIGURATION (Optional)
# ============================================
# Set to true to store uploaded files in Azure Blob Storage
USE_BLOB_STORAGE=false

# Azure Storage Account (when USE_BLOB_STORAGE=true)
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
# OR use account URL with managed identity:
AZURE_STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net
AZURE_STORAGE_CONTAINER=application-packets

# Local storage path (when USE_BLOB_STORAGE=false)
LOCAL_STORAGE_PATH=./data/uploads
