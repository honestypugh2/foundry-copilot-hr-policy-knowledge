# =============================================================================
# HR Policy Knowledge Agent — Pattern A Only (Minimal Configuration)
# =============================================================================
# Use this file if you ONLY need Pattern A (Copilot Studio → Azure AI Search
# directly). Copy to .env and fill in your values.
#
# Pattern A requires NO Foundry project, NO agent code, and NO backend server.
# You only need: Azure AI Search + Azure OpenAI (for embeddings) + Copilot Studio.
# =============================================================================

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your_search_admin_key
AZURE_SEARCH_INDEX_NAME=hr-policy-index

# Azure OpenAI (used by the indexer for embeddings only)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_api_key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini

# Azure Document Intelligence (used by the indexer for document extraction)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Authentication
USE_MANAGED_IDENTITY=true

# Pattern selection
ORCHESTRATOR_PATTERN=A
SEARCH_MODE=integrated_vectorization

# Knowledge Base Path
KNOWLEDGE_BASE_PATH=./data/knowledge_base/ASK HR Knowledge
